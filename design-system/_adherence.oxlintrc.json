{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/composite/**",
              "components/primitives/**",
              "components/sections/**",
              "ui_kits/rutina/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Archivo|Archivo Expanded))/i]",
        "message": "Font not provided by the design system. Available: Archivo, Archivo Expanded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: items, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|imageAlt|tag|title|body|linkLabel|href|style|key|ref|className|style|children)$/]",
        "message": "<ArticleCard> doesn't accept that prop. Declared props: image, imageAlt, tag, title, body, linkLabel, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BackToTop'] > JSXAttribute > JSXIdentifier[name!=/^(?:visible|onClick|style|key|ref|className|style|children)$/]",
        "message": "<BackToTop> doesn't accept that prop. Declared props: visible, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, size, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|ink|success|info|danger|neutral)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'ink' | 'success' | 'info' | 'danger' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Badge> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|href|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, href, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|inverse)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|size|style|key|ref|className|style|children)$/]",
        "message": "<CheckList> doesn't accept that prop. Declared props: items, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckList'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<CheckList> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClubFinder'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|highlight|subtitle|placeholder|cities|onSearch|style|key|ref|className|style|children)$/]",
        "message": "<ClubFinder> doesn't accept that prop. Declared props: title, highlight, subtitle, placeholder, cities, onSearch, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DetailItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|style|key|ref|className|style|children)$/]",
        "message": "<DetailItem> doesn't accept that prop. Declared props: label, value, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EquipmentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|modelCode|series|imageUrl|primaryMuscles|secondaryMuscles|description|weight|videoHref|manualHref|style|key|ref|className|style|children)$/]",
        "message": "<EquipmentCard> doesn't accept that prop. Declared props: name, modelCode, series, imageUrl, primaryMuscles, secondaryMuscles, description, weight, videoHref, manualHref, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExerciseCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|name|muscles|details|equipment|alternative|imageUrl|steps|videoHref|style|key|ref|className|style|children)$/]",
        "message": "<ExerciseCard> doesn't accept that prop. Declared props: number, name, muscles, details, equipment, alternative, imageUrl, steps, videoHref, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureSplit'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|checks|imageUrl|imageAlt|cta|reverse|tone|style|key|ref|className|style|children)$/]",
        "message": "<FeatureSplit> doesn't accept that prop. Declared props: title, body, checks, imageUrl, imageAlt, cta, reverse, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureSplit'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|ink)$/]",
        "message": "<FeatureSplit> tone must be one of 'light' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<FilterPill> doesn't accept that prop. Declared props: active, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|highlight|subtitle|note|imageUrl|imageAlt|overlayText|primaryCta|secondaryCta|tone|style|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: title, highlight, subtitle, note, imageUrl, imageAlt, overlayText, primaryCta, secondaryCta, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:orange|light)$/]",
        "message": "<Hero> tone must be one of 'orange' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:search|check|chevron-down|arrow-up|arrow-right|map-pin|user|info|clock|droplet|calendar|pencil|alert-triangle|alert-octagon|x|menu|smartphone|phone|globe|plus|minus|chevron-up|chevron-left|chevron-right|external-link|download|play|filter|sliders|bell|lock|star|home|mail|credit-card|repeat|dumbbell|flame|heart|trending-up|bar-chart-2|target|timer|trophy)$/]",
        "message": "<Icon> name must be one of 'search' | 'check' | 'chevron-down' | 'arrow-up' | 'arrow-right' | 'map-pin' | 'user' | 'info' | 'clock' | 'droplet' | 'calendar' | 'pencil' | 'alert-triangle' | 'alert-octagon' | 'x' | 'menu' | 'smartphone' | 'phone' | 'globe' | 'plus' | 'minus' | 'chevron-up' | 'chevron-left' | 'chevron-right' | 'external-link' | 'download' | 'play' | 'filter' | 'sliders' | 'bell' | 'lock' | 'star' | 'home' | 'mail' | 'credit-card' | 'repeat' | 'dumbbell' | 'flame' | 'heart' | 'trending-up' | 'bar-chart-2' | 'target' | 'timer' | 'trophy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MobileMenu'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|activeId|utilities|language|ctaLabel|logoSrc|onClose|style|key|ref|className|style|children)$/]",
        "message": "<MobileMenu> doesn't accept that prop. Declared props: items, activeId, utilities, language, ctaLabel, logoSrc, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavMenu'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|activeId|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<NavMenu> doesn't accept that prop. Declared props: items, activeId, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|tone|children|style|key|ref|className|style|children)$/]",
        "message": "<NoteItem> doesn't accept that prop. Declared props: title, tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NoteItem'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|success|danger)$/]",
        "message": "<NoteItem> tone must be one of 'neutral' | 'success' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageFooter'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|columns|lines|children|style|key|ref|className|style|children)$/]",
        "message": "<PageFooter> doesn't accept that prop. Declared props: logoSrc, columns, lines, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|breadcrumb|title|subtitle|badge|badgeTone|meta|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<PageHeader> doesn't accept that prop. Declared props: tone, breadcrumb, title, subtitle, badge, badgeTone, meta, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|ink)$/]",
        "message": "<PageHeader> tone must be one of 'light' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHeader'] > JSXAttribute[name.name='badgeTone'] > Literal[value!=/^(?:brand|ink|success)$/]",
        "message": "<PageHeader> badgeTone must be one of 'brand' | 'ink' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|oldPrice|period|feeNote|promoNote|features|flag|ctaLabel|ctaHref|style|key|ref|className|style|children)$/]",
        "message": "<PriceCard> doesn't accept that prop. Declared props: name, price, oldPrice, period, feeNote, promoNote, features, flag, ctaLabel, ctaHref, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RuleItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|style|key|ref|className|style|children)$/]",
        "message": "<RuleItem> doesn't accept that prop. Declared props: icon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|subtitle|items|children|style|key|ref|className|style|children)$/]",
        "message": "<SectionBanner> doesn't accept that prop. Declared props: tone, title, subtitle, items, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|ink|neutral|success|info)$/]",
        "message": "<SectionBanner> tone must be one of 'brand' | 'ink' | 'neutral' | 'success' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:usps|utilities|navItems|ctaLabel|ctaHref|logoSrc|style|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: usps, utilities, navItems, ctaLabel, ctaHref, logoSrc, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|inverse|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, label, inverse, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SummaryTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:columns|rows|style|key|ref|className|style|children)$/]",
        "message": "<SummaryTable> doesn't accept that prop. Declared props: columns, rows, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|primary|secondary)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'primary' | 'secondary'."
      }
    ]
  },
