{
  "name": "basicfit-rutina",
  "version": "1.2.0",
  "description": "BasicFit Equipment Catalog and Routine Generator",
  "scripts": {
    "serve": "npx --yes serve . -p 3000",
    "extract-images": "node scripts/extract-matrix-images-puppeteer.js",
    "extract-images-all": "node scripts/extract-matrix-images-puppeteer.js --all",
    "extract-images-list": "node scripts/extract-matrix-images-puppeteer.js --list",
    "validate-data": "node scripts/validate-data.js",
    "validate-rutina": "node scripts/validate-rutina.js",
    "build-rutina": "node scripts/build-rutina.js",
    "build-catalog": "node scripts/build-catalog.js",
    "build-guide": "node scripts/build-guide-content.js",
    "build-gyms": "node scripts/build-gyms.js",
    "predev": "npm run build-guide && npm run build-gyms",
    "dev": "vite",
    "prebuild": "npm run build-guide && npm run build-gyms",
    "build": "vite build",
    "postbuild": "node scripts/copy-static-pages.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:viewport": "node tests/viewport-check.js"
  },
  "keywords": [
    "fitness",
    "gym",
    "equipment",
    "basicfit",
    "matrix"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "idb": "^8.0.0",
    "puppeteer": "^23.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "marked": "^15.0.12",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8"
  }
}
